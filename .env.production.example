# =============================================================================
# Railway + Vercel Production Environment Variables
# =============================================================================
# This file documents the EXACT variable names each service reads from code.
# On Railway, set these directly in each service's Variables tab.
# Do NOT use the docker-compose variable names (MYSQL_HOST, MYSQL_USER, etc.)
# because docker-compose translates those — Railway does not.
#
# Replace every <PLACEHOLDER> with a real value before deploying.
# =============================================================================


# =============================================================================
# auth-service (Railway service)
# =============================================================================
# Dockerfile: docker/railway-auth-service.Dockerfile

NODE_ENV=production
TYPEORM_SYNC=false

# Database — get these from Railway MySQL service > Variables/Connect tab
DB_HOST=<railway-mysql-private-host>
DB_PORT=3306
DB_USERNAME=<railway-mysql-user>
DB_PASSWORD=<railway-mysql-password>
DB_DATABASE=dexa_auth

# JWT — generate a real secret: openssl rand -hex 32
JWT_SECRET=<generate-a-64-char-hex-string>
JWT_EXPIRES_IN=8h

# Seed admin account — created on first startup
ADMIN_EMAIL=admin@dexa.test
ADMIN_PASSWORD=<choose-a-strong-admin-password>

# TCP microservice bind address — :: means all interfaces (IPv4 + IPv6)
AUTH_SERVICE_BIND_HOST=::
AUTH_SERVICE_PORT=3101


# =============================================================================
# employee-service (Railway service)
# =============================================================================
# Dockerfile: docker/railway-employee-service.Dockerfile

NODE_ENV=production
TYPEORM_SYNC=false

# Database — same MySQL host, different database name
DB_HOST=<railway-mysql-private-host>
DB_PORT=3306
DB_USERNAME=<railway-mysql-user>
DB_PASSWORD=<railway-mysql-password>
DB_DATABASE=dexa_employee

# TCP microservice bind address
EMPLOYEE_SERVICE_BIND_HOST=::
EMPLOYEE_SERVICE_PORT=3102


# =============================================================================
# attendance-service (Railway service)
# =============================================================================
# Dockerfile: docker/railway-attendance-service.Dockerfile

NODE_ENV=production
TYPEORM_SYNC=false
APP_TIMEZONE=Asia/Jakarta

# Database — same MySQL host, different database name
DB_HOST=<railway-mysql-private-host>
DB_PORT=3306
DB_USERNAME=<railway-mysql-user>
DB_PASSWORD=<railway-mysql-password>
DB_DATABASE=dexa_attendance

# TCP microservice bind address
ATTENDANCE_SERVICE_BIND_HOST=::
ATTENDANCE_SERVICE_PORT=3103

# Upload and geolocation rules
MAX_UPLOAD_BYTES=2097152
MAX_LOCATION_ACCURACY_METERS=500

# Proof photo storage — use s3 for Railway, local for development
PROOF_STORAGE_DRIVER=s3
S3_ENDPOINT=<bucket-s3-endpoint>
S3_BUCKET=<bucket-name>
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=<bucket-access-key>
S3_SECRET_ACCESS_KEY=<bucket-secret-key>
S3_KEY_PREFIX=attendance-proofs
S3_FORCE_PATH_STYLE=true

# If not using S3, set PROOF_STORAGE_DRIVER=local and set UPLOAD_DIR:
# PROOF_STORAGE_DRIVER=local
# UPLOAD_DIR=/app/uploads/attendance


# =============================================================================
# api-gateway (Railway service — the ONLY service with a public domain)
# =============================================================================
# Dockerfile: docker/railway-api-gateway.Dockerfile

NODE_ENV=production

# JWT — must be the SAME secret as auth-service
JWT_SECRET=<same-secret-as-auth-service>

# Internal service connections — Railway private DNS names
AUTH_SERVICE_HOST=<railway-auth-service-private-hostname>
AUTH_SERVICE_PORT=3101
EMPLOYEE_SERVICE_HOST=<railway-employee-service-private-hostname>
EMPLOYEE_SERVICE_PORT=3102
ATTENDANCE_SERVICE_HOST=<railway-attendance-service-private-hostname>
ATTENDANCE_SERVICE_PORT=3103

# CORS — set to the final Vercel URL after deploying frontend
CORS_ORIGIN=<your-vercel-url>

# Cookie settings for cross-origin auth (Vercel <-> Railway)
AUTH_COOKIE_NAME=dexa_access_token
CSRF_COOKIE_NAME=dexa_csrf_token
AUTH_COOKIE_MAX_AGE_SECONDS=28800
CSRF_COOKIE_MAX_AGE_SECONDS=28800
COOKIE_SECURE=true
COOKIE_SAMESITE=none
COOKIE_DOMAIN=

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Upload size limit (must match attendance-service)
MAX_UPLOAD_BYTES=2097152
MAX_LOCATION_ACCURACY_METERS=500


# =============================================================================
# Vercel frontend (set in Vercel dashboard > Settings > Environment Variables)
# =============================================================================

VITE_API_BASE_URL=<your-railway-api-gateway-public-url>
