NODE_ENV=production
APP_TIMEZONE=Asia/Jakarta
TYPEORM_SYNC=false

# Shared backend security
JWT_SECRET=replace-with-a-production-random-secret
JWT_EXPIRES_IN=8h
AUTH_COOKIE_NAME=dexa_access_token
CSRF_COOKIE_NAME=dexa_csrf_token
AUTH_COOKIE_MAX_AGE_SECONDS=28800
CSRF_COOKIE_MAX_AGE_SECONDS=28800
COOKIE_SECURE=true
COOKIE_SAMESITE=none
COOKIE_DOMAIN=
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Public frontend/backend origins
CORS_ORIGIN=https://your-vercel-app.vercel.app
VITE_API_BASE_URL=https://your-api-gateway.up.railway.app

# Railway private service hosts for api-gateway
AUTH_SERVICE_HOST=auth-service.railway.internal
AUTH_SERVICE_PORT=3101
EMPLOYEE_SERVICE_HOST=employee-service.railway.internal
EMPLOYEE_SERVICE_PORT=3102
ATTENDANCE_SERVICE_HOST=attendance-service.railway.internal
ATTENDANCE_SERVICE_PORT=3103

# Internal service bind hosts
AUTH_SERVICE_BIND_HOST=::
EMPLOYEE_SERVICE_BIND_HOST=::
ATTENDANCE_SERVICE_BIND_HOST=::

# MySQL. Map these from Railway MySQL variables per service.
DB_HOST=mysql.railway.internal
DB_PORT=3306
DB_USERNAME=
DB_PASSWORD=
AUTH_DB_NAME=dexa_auth
EMPLOYEE_DB_NAME=dexa_employee
ATTENDANCE_DB_NAME=dexa_attendance

# Seeded admin. Change this before public deployment.
ADMIN_EMAIL=admin@dexa.test
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Attendance upload and geolocation rules
MAX_UPLOAD_BYTES=2097152
MAX_LOCATION_ACCURACY_METERS=500

# S3-compatible private bucket for attendance proof photos.
PROOF_STORAGE_DRIVER=s3
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_KEY_PREFIX=attendance-proofs
S3_FORCE_PATH_STYLE=true
