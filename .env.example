NODE_ENV=development
APP_TIMEZONE=Asia/Jakarta

MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=dexa_user
MYSQL_PASSWORD=dexa_password

AUTH_DB_NAME=dexa_auth
EMPLOYEE_DB_NAME=dexa_employee
ATTENDANCE_DB_NAME=dexa_attendance

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h

ADMIN_EMAIL=admin@dexa.test
ADMIN_PASSWORD=Admin12345!

AUTH_SERVICE_HOST=auth-service
AUTH_SERVICE_PORT=3101
EMPLOYEE_SERVICE_HOST=employee-service
EMPLOYEE_SERVICE_PORT=3102
ATTENDANCE_SERVICE_HOST=attendance-service
ATTENDANCE_SERVICE_PORT=3103

API_GATEWAY_PORT=4000
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
AUTH_COOKIE_NAME=dexa_access_token
CSRF_COOKIE_NAME=dexa_csrf_token
AUTH_COOKIE_MAX_AGE_SECONDS=28800
CSRF_COOKIE_MAX_AGE_SECONDS=28800
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

PROOF_STORAGE_DRIVER=local
UPLOAD_DIR=uploads/attendance
MAX_UPLOAD_BYTES=2097152
MAX_LOCATION_ACCURACY_METERS=500
TYPEORM_SYNC=false

# S3-compatible proof storage for production deployments such as Railway Buckets.
# Set PROOF_STORAGE_DRIVER=s3 and provide these values from the bucket credentials.
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_KEY_PREFIX=attendance-proofs
S3_FORCE_PATH_STYLE=true
